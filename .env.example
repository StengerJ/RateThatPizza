PGH_POSTGRES_DB=pgh_pizza
PGH_POSTGRES_USER=postgres
PGH_POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

PGH_JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-characters
PGH_JWT_ISSUER=pgh-pizza-api
PGH_JWT_EXPIRES_MINUTES=120

PGH_ADMIN_EMAIL=admin@pgh-pizza.local
PGH_ADMIN_PASSWORD=replace-with-a-strong-admin-password
PGH_ADMIN_DISPLAY_NAME=PGH Admin

PGH_SERVER_NAME=yourdomain.com
PGH_SITE_ADDRESS=yourdomain.com
PGH_FRONTEND_BASE_URL=https://yourdomain.com
PGH_ENABLE_HTTPS=true
PGH_CERTBOT_EMAIL=you@example.com

FRONTEND_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8080
POSTGRES_PORT=5432
SERVER_ADDRESS=127.0.0.1
JAVA_OPTS=

SMTP_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_AUTH=false
SMTP_STARTTLS=false
