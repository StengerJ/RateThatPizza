# Public site
PGH_SITE_ADDRESS="pghpizza.org, www.pghpizza.org"
PGH_TLS_SERVER_NAME=pghpizza.org
PGH_FRONTEND_BASE_URL=https://pghpizza.org
FRONTEND_PORT=80
HTTPS_PORT=443

# Database
PGH_POSTGRES_DB=pgh_pizza
PGH_POSTGRES_USER=postgres
PGH_POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# Authentication
PGH_JWT_SECRET=replace-with-a-long-random-jwt-secret-at-least-32-characters
PGH_JWT_ISSUER=pgh-pizza-api
PGH_JWT_EXPIRES_MINUTES=120

# Initial admin account
PGH_ADMIN_EMAIL=admin@pgh-pizza.local
PGH_ADMIN_PASSWORD=replace-with-a-strong-admin-password
PGH_ADMIN_DISPLAY_NAME="PGH-pizza Admin"

# Email
SMTP_ENABLED=true
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_USERNAME=aa1b3d001@smtp-brevo.com
SMTP_PASSWORD=replace-with-your-brevo-smtp-key
SMTP_FROM=no-reply@pghpizza.org
SMTP_AUTH=true
SMTP_STARTTLS=false
